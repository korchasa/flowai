{"parentUuid":"a8","type":"assistant","message":{"role":"assistant","content":[{"type":"tool_use","name":"Write","input":{"file_path":"src/lib/rate-limiter.ts","content":"export class RateLimiter {\n  private store = new Map<string, { count: number; resetAt: number }>();\n  constructor(private options: { maxRequests: number; windowMs: number }) {}\n  async isRateLimited(key: string): Promise<boolean> {\n    const now = Date.now();\n    const entry = this.store.get(key);\n    if (!entry || now > entry.resetAt) {\n      this.store.set(key, { count: 1, resetAt: now + this.options.windowMs });\n      return false;\n    }\n    entry.count++;\n    return entry.count > this.options.maxRequests;\n  }\n}"}}]},"uuid":"a9","timestamp":"2026-04-08T11:00:30.000Z","sessionId":"sess-2026-04-08"}
