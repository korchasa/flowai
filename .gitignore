.DS_Store
.vscode
skeleton.md
tmp/
benchmarks/runs/
benchmarks/benchmarks.lock
# benchmarks/cache/ is intentionally tracked — committed per-scenario verdicts
# short-circuit agent + judge calls when inputs haven't changed (FR-BENCH-CACHE).
framework/skills/*/benchmarks/runs/
framework/**/flowai-skill-example/
.env
__pycache__/
_research_tmp/

# Temporary worktrees (created by Claude Code isolation)
.claude/worktrees/

# Synced from framework/ via `deno task sync-local` (dev-only, not tracked)
.claude/flowai-hooks.json
.claude/settings.local.json
.claude/*/flowai-*
.claude/assets/

# Generated artifacts (cli)
cli/src/bundled.json
cli/src/_version.ts

.flowai/runs/
.claude/scheduled_tasks.lock
