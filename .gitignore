.DS_Store
.vscode
skeleton.md
tmp/
acceptance-tests/runs/
acceptance-tests/acceptance-tests.lock
# acceptance-tests/cache/ is intentionally tracked — committed per-scenario verdicts
# short-circuit agent + judge calls when inputs haven't changed (FR-ACCEPT-CACHE).
framework/*/skills/*/acceptance-tests/runs/
framework/*/commands/*/acceptance-tests/runs/
framework/*/agents/*/acceptance-tests/runs/
framework/**/flowai-example/
.env
__pycache__/
_research_tmp/

# Temporary worktrees (created by Claude Code isolation)
.claude/worktrees/

# Synced from framework/ via `deno task sync-local` (dev-only, not tracked)
.claude/flowai-hooks.json
.claude/settings.local.json
.claude/*/flowai-*
.claude/assets/

# Generated artifacts (cli)
cli/src/bundled.json
cli/src/_version.ts

# Generated artifacts (Claude Code plugin marketplace — FR-DIST.MARKETPLACE)
dist/

.flowai/runs/
.claude/scheduled_tasks.lock
