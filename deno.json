{
  "name": "@korchasa/flowai",
  "version": "0.12.11",
  "exports": "./cli/src/main.ts",
  "license": "MIT",
  "publish": {
    "include": [
      "cli/src/"
    ],
    "exclude": [
      "!cli/src/bundled.json",
      "!cli/src/_version.ts"
    ]
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@denosaurs/wait": "jsr:@denosaurs/wait@^0.2.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/fs": "jsr:@std/fs@^1.0.17",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/semver": "jsr:@std/semver@^1.0.0",
    "@std/toml": "jsr:@std/toml@^1.0.2",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "zod": "npm:zod@^3.25.76",
    "@acceptance-tests/": "./scripts/acceptance-tests/lib/"
  },
  "tasks": {
    "check": "deno run -A scripts/task-check.ts",
    "test": "deno run -A scripts/task-test.ts",
    "dev": "deno run -A scripts/task-dev.ts",
    "acceptance-tests": "deno run -A scripts/task-acceptance-tests.ts",
    "sync-local": "deno run -A scripts/task-sync-local.ts",
    "sync-global": "deno run -A scripts/task-sync-global.ts",
    "bundle": "deno run -A cli/scripts/bundle-framework.ts",
    "release": "deno run -A npm:standard-version --skip.tag"
  },
  "lint": {
    "exclude": [
      "framework/*/skills/*/acceptance-tests/",
      "framework/*/commands/*/acceptance-tests/",
      "framework/*/agents/*/acceptance-tests/",
      "framework/*/acceptance-tests/*/fixture/"
    ]
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "**/*.md",
      ".cursor/",
      ".claude/",
      ".flowai.yaml",
      "framework/*/skills/*/acceptance-tests/*/fixture/",
      "framework/*/commands/*/acceptance-tests/*/fixture/",
      "framework/*/agents/*/acceptance-tests/*/fixture/",
      "framework/*/acceptance-tests/*/fixture/"
    ]
  }
}
